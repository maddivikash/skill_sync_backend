# Caddy reverse proxy — automatic HTTPS via Let's Encrypt.
# Serves the SPA on / and proxies /api/* to the backend (same origin).
# Both hostnames are served: ascenddaily.in (primary; cert auto-issues once
# its DNS resolves) and the duckdns fallback (keeps the app live meanwhile).
{
	email vickyvikashmaddi@gmail.com
}

ascenddaily.in, skillsync-io.duckdns.org {
	handle_path /api/* {
		reverse_proxy api:8000
	}
	handle {
		reverse_proxy web:80
	}
}

# Redirect www -> apex.
www.ascenddaily.in {
	redir https://ascenddaily.in{uri} permanent
}
